{
  "name": "cs2-overlay-electron",
  "version": "1.0.0",
  "description": "CS2 broadcast overlay for OBS",
  "author": "Cs2Overlay",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npx electron .",
    "build:win": "npx electron-builder --win msi --x64",
    "build:win:dir": "npx electron-builder --win dir --x64",
    "build:win:msi": "npx electron-builder --win msi --x64"
  },
  "build": {
    "appId": "com.cs2overlay.electron",
    "productName": "Cs2Overlay",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "msi"
      ]
    },
    "asar": true
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}

