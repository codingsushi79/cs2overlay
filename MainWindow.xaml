<Window x:Class="Cs2Overlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cs2Overlay"
        Width="1920"
        Height="1080"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Lime"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Grid>
        <!-- TOP SCORE STRIP -->
        <Grid VerticalAlignment="Top" Margin="0,16,0,0" Height="84" HorizontalAlignment="Center" Width="980">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*" />
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="2.4*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{Binding TeamLeftBarBrush}" CornerRadius="16,0,0,16">
                <Border.RenderTransform>
                    <SkewTransform AngleX="-10" />
                </Border.RenderTransform>
                <Grid Margin="22,8,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="assets/logo_left.png" Width="48" Height="48" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TeamLeftName}" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding TeamLeftScore}" Foreground="White" FontSize="34" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Right"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#EE10131A">
                <Grid Margin="8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding RoundInfo}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="{Binding RoundTimer}" Foreground="#FFFDE057" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{Binding TeamRightBarBrush}" CornerRadius="0,16,16,0">
                <Border.RenderTransform>
                    <SkewTransform AngleX="10" />
                </Border.RenderTransform>
                <Grid Margin="10,8,22,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding TeamRightScore}" Foreground="White" FontSize="34" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TeamRightName}" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Right"/>
                    <Image Grid.Column="2" Source="assets/logo_right.png" Width="48" Height="48" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- TOP LEFT MINIMAP -->
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="18,18,0,0"
                Width="250"
                Height="250"
                Background="#E0000000"
                CornerRadius="10">
            <Grid>
                <Image Source="assets/minimap_frame.png" Stretch="Fill" Opacity="0.8"/>
                <Border Margin="12" CornerRadius="8" ClipToBounds="True">
                    <Image Source="assets/radar_background.png" Stretch="Fill"/>
                </Border>
            </Grid>
        </Border>

        <!-- CS2 PROCESS STATUS -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,106,0,0" Background="#AA000000" CornerRadius="8" Padding="10,4">
            <TextBlock Text="{Binding Cs2StatusText}" Foreground="{Binding Cs2StatusBrush}" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <!-- BOTTOM HUD -->
        <Grid VerticalAlignment="Bottom" Margin="24,0,24,18" Height="152">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="1.7*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <!-- Left (T) players -->
            <ItemsControl Grid.Column="0" ItemsSource="{Binding TeamRightPlayers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="135" Height="148" Margin="2,0">
                            <Border CornerRadius="8" Background="#E213151B" Opacity="{Binding CardOpacity}"/>
                            <Rectangle VerticalAlignment="Bottom"
                                       Height="{Binding DamageFillHeight}"
                                       Fill="{Binding TeamDamageFillBrush}"
                                       Opacity="{Binding DamageFillOpacity}"
                                       RadiusX="6"
                                       RadiusY="6"/>
                            <Border CornerRadius="8" BorderBrush="#33000000" BorderThickness="1" Opacity="{Binding CardOpacity}"/>
                            <Grid Margin="8,8,8,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="20"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Health}" Foreground="#FFFFFFFF" FontWeight="Bold" FontSize="22" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="{Binding NameBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding WeaponIcon}" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding WeaponShortName}" Foreground="{Binding NameBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Text="{Binding MoneyText}" Foreground="#FF6FF36F" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                            </Grid>
                            <Border Background="#88000000" CornerRadius="8" Visibility="{Binding DeadOverlayVisibility}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Center POV panel -->
            <Border Grid.Column="1" Background="#F0182430" CornerRadius="10" Margin="8,6" BorderBrush="#AA2D92FF" BorderThickness="2">
                <Grid Margin="10,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>
                    <Image Source="{Binding FocusPlayerAvatar}" Stretch="UniformToFill"/>
                    <TextBlock Grid.Row="1" Text="{Binding FocusPlayerName}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Right (CT) players -->
            <ItemsControl Grid.Column="2" ItemsSource="{Binding TeamLeftPlayers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="135" Height="148" Margin="2,0">
                            <Border CornerRadius="8" Background="#E213151B" Opacity="{Binding CardOpacity}"/>
                            <Rectangle VerticalAlignment="Bottom"
                                       Height="{Binding DamageFillHeight}"
                                       Fill="{Binding TeamDamageFillBrush}"
                                       Opacity="{Binding DamageFillOpacity}"
                                       RadiusX="6"
                                       RadiusY="6"/>
                            <Border CornerRadius="8" BorderBrush="#33000000" BorderThickness="1" Opacity="{Binding CardOpacity}"/>
                            <Grid Margin="8,8,8,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="20"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Health}" Foreground="#FFFFFFFF" FontWeight="Bold" FontSize="22" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="{Binding NameBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding WeaponIcon}" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding WeaponShortName}" Foreground="{Binding NameBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Text="{Binding MoneyText}" Foreground="#FF6FF36F" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                            </Grid>
                            <Border Background="#88000000" CornerRadius="8" Visibility="{Binding DeadOverlayVisibility}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Window>

